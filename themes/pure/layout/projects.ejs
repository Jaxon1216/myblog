<main class="main" role="main">
  <article class="article article-type-normal" itemscope="">
    <header class="article-header">
      <h1 itemprop="title"><%= page.title %></h1>
      <% if(page.description) { %>
      <p class="text-muted"><%= page.description %></p>
      <% } %>
    </header>
    
    <div class="article-body">
      <%- page.content %>
    </div>
    
    <!-- 项目列表 -->
    <% if(theme.project_list && theme.project_list.length) { %>
    <div class="projects-grid">
      <% theme.project_list.forEach(function(project) { %>
      <div class="project-item panel panel-default">
        <div class="panel-body">
          <h4 class="project-title">
            <% if(project.link) { %>
            <a href="<%= project.link %>" target="_blank"><%= project.name %></a>
            <% } else { %>
            <%= project.name %>
            <% } %>
          </h4>
          <p class="project-desc text-muted"><%= project.description %></p>
          <% if(project.tags && project.tags.length) { %>
          <div class="project-tags">
            <% project.tags.forEach(function(tag) { %>
            <span class="label label-primary"><%= tag %></span>
            <% }) %>
          </div>
          <% } %>
          <div class="project-links mt">
            <% if(project.link) { %>
            <a href="<%= project.link %>" target="_blank" class="btn btn-sm btn-default">
              <i class="icon-link"></i> 预览
            </a>
            <% } %>
            <% if(project.github) { %>
            <a href="<%= project.github %>" target="_blank" class="btn btn-sm btn-default">
              <i class="icon-github"></i> 源码
            </a>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </article>
</main>

